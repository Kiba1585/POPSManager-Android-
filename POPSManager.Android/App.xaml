<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POPSManager.Android.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 🎨 PALETA DE COLORES OSCUROS -->
            <!-- ═══════════════════════════════════════════ -->
            <Color x:Key="BackgroundPrimary">#0D1117</Color>
            <Color x:Key="BackgroundSecondary">#161B22</Color>
            <Color x:Key="SurfaceColor">#1C2128</Color>
            <Color x:Key="BorderColor">#30363D</Color>
            <Color x:Key="AccentBlue">#58A6FF</Color>
            <Color x:Key="AccentGreen">#3FB950</Color>
            <Color x:Key="AccentOrange">#D29922</Color>
            <Color x:Key="AccentRed">#F85149</Color>
            <Color x:Key="TextPrimary">#F0F6FC</Color>
            <Color x:Key="TextSecondary">#8B949E</Color>
            <Color x:Key="TextMuted">#6E7681</Color>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 🖊️ ESTILOS DE TIPOGRAFÍA -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="PageTitle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style x:Key="SectionTitle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
            </Style>
            <Style x:Key="StatusLabel" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 🧱 ESTILOS DE TARJETAS (CARDS) -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="CardFrame" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="HasShadow" Value="False" />
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 🖱️ ESTILOS DE BOTONES -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
            </Style>
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentRed}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 📝 ESTILOS DE ENTRADA DE TEXTO -->
            <!-- ═══════════════════════════════════════════ -->
            <Style x:Key="DarkEntry" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondary}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>