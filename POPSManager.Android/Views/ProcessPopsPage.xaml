<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POPSManager.Android.Views.ProcessPopsPage"
             Title="Procesar POPS"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.Resources>
        <DataTemplate x:Key="GameListTemplate">
            <Label Text="{Binding Name}"
                   TextColor="{StaticResource TextPrimary}"
                   FontSize="14"
                   Margin="0,6" />
        </DataTemplate>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- Carpeta raíz OPL -->
            <Label Text="📁 Carpeta raíz OPL:" Style="{StaticResource SectionTitle}" />
            <Entry Text="{Binding OplRootFolder}" Placeholder="Ruta de la raíz OPL" Style="{StaticResource DarkEntry}" />
            <Button Text="Seleccionar raíz OPL" Command="{Binding SelectOplRootFolderCommand}"
                    Style="{StaticResource PrimaryButton}" ImageSource="folder_open.png" />

            <!-- Ajustes de almacenamiento -->
            <Button Text="🔧 Abrir ajustes de almacenamiento" Command="{Binding OpenStorageSettingsCommand}"
                    Style="{StaticResource DangerButton}" Margin="0,6,0,0" />

            <!-- Opciones de cheats -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎮 Opciones de cheats" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatWidescreen}" OnColor="{StaticResource AccentBlue}" />
                        <Label Text="Widescreen" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatNoPal}" OnColor="{StaticResource AccentBlue}" />
                        <Label Text="Desactivar PAL ($NOPAL)" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatFixSound}" OnColor="{StaticResource AccentBlue}" />
                        <Label Text="Arreglar sonido" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatFixGraphics}" OnColor="{StaticResource AccentBlue}" />
                        <Label Text="Arreglar gráficos" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Acciones -->
            <Label Text="⚡ Acciones" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <FlexLayout Wrap="Wrap" JustifyContent="Start">
                <Button Text="🚀 Procesar todo" Command="{Binding ProcessAllCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,10" />
                <Button Text="🧩 Generar ELFs" Command="{Binding GenerateElfCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,10" />
                <Button Text="🎯 Generar Cheats" Command="{Binding GenerateCheatsCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,10" />
                <Button Text="🖼️ Descargar Covers" Command="{Binding DownloadCoversCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,10" />
                <Button Text="📋 Copiar Metadatos" Command="{Binding CopyMetadataCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,10" />
                <Button Text="✏️ Renombrar juegos" Command="{Binding RenameAllCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" />
                <Button Text="🔄 Refrescar listas" Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" />
            </FlexLayout>

            <!-- Modo de actualización + botón -->
            <HorizontalStackLayout Spacing="10" Margin="0,-5,0,0">
                <Switch IsToggled="{Binding IsUpdateModeIndividual}" OnColor="{StaticResource AccentBlue}" />
                <Label Text="Solo juegos detectados" VerticalOptions="Center" TextColor="{StaticResource TextSecondary}" />
            </HorizontalStackLayout>
            <Button Text="📦 Actualizar DB" Command="{Binding UpdateDatabaseCommand}"
                    Style="{StaticResource SecondaryButton}" />

            <!-- Estado -->
            <Label Text="{Binding Status}" Style="{StaticResource StatusLabel}" />

            <!-- Listas de juegos -->
            <Label Text="🎮 PS1 Games" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <CollectionView ItemsSource="{Binding Ps1Games}" ItemTemplate="{StaticResource GameListTemplate}" />
            <Label Text="💿 PS2 Games" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <CollectionView ItemsSource="{Binding Ps2Games}" ItemTemplate="{StaticResource GameListTemplate}" />
            <Label Text="📱 APPs" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
            <CollectionView ItemsSource="{Binding AppsGames}" ItemTemplate="{StaticResource GameListTemplate}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>