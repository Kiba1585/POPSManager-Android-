<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POPSManager.Android.Views.ProcessPopsPage"
             Title="Procesar POPS">

    <ContentPage.Resources>
        <DataTemplate x:Key="GameListTemplate">
            <Label Text="{Binding Name}"
                   TextColor="White"
                   FontSize="14"
                   Margin="0,4" />
        </DataTemplate>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Carpeta raíz OPL -->
            <Label Text="Carpeta raíz OPL:"
                   FontSize="14"
                   TextColor="#CCCCCC" />
            <Entry Text="{Binding OplRootFolder}"
                   Placeholder="Ruta de la raíz OPL"
                   BackgroundColor="#2D2D2D"
                   TextColor="White" />
            <Button Text="Seleccionar raíz OPL"
                    Command="{Binding SelectOplRootFolderCommand}"
                    BackgroundColor="#4CC2FF"
                    TextColor="White" />

            <!-- Opciones de cheats -->
            <Frame BackgroundColor="#2D2D2D"
                   Padding="10"
                   CornerRadius="10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Opciones de cheats"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatWidescreen}" />
                        <Label Text="Widescreen"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatNoPal}" />
                        <Label Text="Desactivar PAL ($NOPAL)"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatFixSound}" />
                        <Label Text="Arreglar sonido"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Switch IsToggled="{Binding CheatFixGraphics}" />
                        <Label Text="Arreglar gráficos"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Acciones -->
            <Label Text="Acciones"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White" />
            <FlexLayout Wrap="Wrap"
                        JustifyContent="Start">
                <Button Text="Procesar todo"
                        Command="{Binding ProcessAllCommand}"
                        BackgroundColor="#2FA0D8"
                        TextColor="White"
                        Margin="0,0,10,10" />
                <Button Text="Generar ELFs"
                        Command="{Binding GenerateElfCommand}"
                        BackgroundColor="#4CC2FF"
                        TextColor="White"
                        Margin="0,0,10,10" />
                <Button Text="Generar Cheats"
                        Command="{Binding GenerateCheatsCommand}"
                        BackgroundColor="#4CC2FF"
                        TextColor="White"
                        Margin="0,0,10,10" />
                <Button Text="Desc. Covers y Metadatos"
                        Command="{Binding DownloadCoversAndMetadataCommand}"
                        BackgroundColor="#4CC2FF"
                        TextColor="White"
                        Margin="0,0,10,10" />
                <Button Text="Renombrar juegos"
                        Command="{Binding RenameAllCommand}"
                        BackgroundColor="#2D2D2D"
                        TextColor="White"
                        Margin="0,0,10,10" />
                <Button Text="Refrescar listas"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="#2D2D2D"
                        TextColor="White"
                        Margin="0,0,10,10" />
            </FlexLayout>

            <!-- Estado -->
            <Label Text="{Binding Status}"
                   FontSize="14"
                   TextColor="#CCCCCC" />

            <!-- Listas de juegos -->
            <Label Text="PS1 Games"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />
            <CollectionView ItemsSource="{Binding Ps1Games}"
                            ItemTemplate="{StaticResource GameListTemplate}" />

            <Label Text="PS2 Games"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />
            <CollectionView ItemsSource="{Binding Ps2Games}"
                            ItemTemplate="{StaticResource GameListTemplate}" />

            <Label Text="APPs"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />
            <CollectionView ItemsSource="{Binding AppsGames}"
                            ItemTemplate="{StaticResource GameListTemplate}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>