<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-android</TargetFrameworks>
    <UseMaui>true</UseMaui>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="8.0.100" />
    <!-- NUEVO: Para FolderPicker y otras utilidades -->
    <PackageReference Include="CommunityToolkit.Maui" Version="9.1.1" />
  </ItemGroup>

  <!-- Referencia al proyecto Core -->
  <ItemGroup>
    <ProjectReference Include="..\POPSManager.Core\POPSManager.Core.csproj" />
  </ItemGroup>

  <!-- XAML -->
  <ItemGroup>
    <MauiXaml Include="App.xaml" />
    <MauiXaml Include="AppShell.xaml" />          <!-- NUEVO -->
    <MauiXaml Include="Views\**\*.xaml" />
  </ItemGroup>

</Project>