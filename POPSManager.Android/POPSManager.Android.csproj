<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-android</TargetFrameworks>
    <UseMaui>true</UseMaui>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Obligatorio en .NET 8 -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="8.0.100" />
  </ItemGroup>

  <!-- Referencia al proyecto Core -->
  <ItemGroup>
    <ProjectReference Include="..\POPSManager.Core\POPSManager.Core.csproj" />
  </ItemGroup>

  <!-- Solo XAML, los .cs se incluyen automáticamente -->
  <ItemGroup>
    <MauiXaml Include="App.xaml" />
    <MauiXaml Include="Views\**\*.xaml" />
  </ItemGroup>

</Project>